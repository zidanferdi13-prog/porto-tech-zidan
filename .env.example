# Optional: URL to receive contact messages (webhook endpoint)
# Example: Discord webhook, Slack incoming webhook, custom API endpoint
CONTACT_WEBHOOK_URL=

# Optional for canonical/og URL in SEO component
VITE_SITE_URL=

# Required if you want to lock /admin in production
VITE_ADMIN_KEY=

# Optional: comma-separated allowed origins for contact API
# Example: https://yourdomain.com,https://www.yourdomain.com
CONTACT_ALLOWED_ORIGINS=
